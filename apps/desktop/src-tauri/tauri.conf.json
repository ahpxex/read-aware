{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ReadAware",
  "version": "0.1.0",
  "identifier": "com.readaware.app",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run --filter @read-aware/web dev",
    "beforeBuildCommand": "bun run --filter @read-aware/web build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ReadAware",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
