{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ReadAware",
  "version": "0.3.0",
  "identifier": "com.readaware.app",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run --filter @read-aware/web dev",
    "beforeBuildCommand": "bun run --filter @read-aware/web build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "ReadAware",
        "dragDropEnabled": false,
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#f5f1e8"
      }
    ],
    "security": {
      "dangerousDisableAssetCspModification": [
        "style-src"
      ],
      "csp": "default-src 'self'; img-src 'self' blob: data: raplugin: http://raplugin.localhost; media-src 'self' blob: data:; style-src 'self' 'unsafe-inline' blob:; font-src 'self' data: blob:; script-src 'self' raplugin: http://raplugin.localhost; worker-src 'self' blob:; frame-src 'self' blob:; connect-src 'self' ipc: http://ipc.localhost blob: https: http://localhost:* http://127.0.0.1:*",
      "devCsp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' blob: data:; img-src 'self' blob: data: https: http: raplugin:; media-src 'self' blob: data: https: http:; style-src 'self' 'unsafe-inline'; font-src 'self' data: blob: https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' raplugin: http://raplugin.localhost; worker-src 'self' blob:; connect-src 'self' ws: wss: http: https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "android": {
      "versionCode": 2000009
    },
    "macOS": {
      "dmg": {
        "background": "./dmg/background.png",
        "windowSize": {
          "width": 660,
          "height": 471
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "bundled-plugins/": "bundled-plugins/"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNCNTBDNjU1QzE1RkNENkYKUldSdnpWL0JWY1pRTytYRE5xNE5tekRQVG9UcWcvbGpNWTdJdGwwejB1WUtrdjlycTdaWEhvUmIK",
      "endpoints": [
        "https://github.com/ahpxex/read-aware/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
