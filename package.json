{
  "name": "read-aware",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev --filter=@read-aware/web",
    "dev:desktop": "turbo run dev --filter=@read-aware/desktop",
    "build": "turbo run build --filter=@read-aware/web",
    "build:desktop": "turbo run build --filter=@read-aware/desktop",
    "typecheck": "turbo run typecheck",
    "storybook": "turbo run storybook --filter=@read-aware/web",
    "build-storybook": "turbo run build-storybook --filter=@read-aware/web"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "turbo": "^2.5.6"
  }
}
